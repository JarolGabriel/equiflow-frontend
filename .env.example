# EquiFlow frontend - environment variables
# Copy this file to `.env.local` and adjust the values.
# Only NEXT_PUBLIC_* variables are exposed to the browser.

# Base URL of the EquiFlow REST API (must include the `/api` prefix, no trailing slash).
# Local backend example: http://localhost:8000/api
NEXT_PUBLIC_API_URL=https://equiflow-axd3d2d8h0ajfze0.westus3-01.azurewebsites.net/api

# Base URL for the alerts WebSocket (Phase 3). Use ws:// locally, wss:// in production.
# The alerts consumer path (e.g. /ws/alerts/) is appended by the client at connection time.
NEXT_PUBLIC_WS_URL=wss://equiflow-axd3d2d8h0ajfze0.westus3-01.azurewebsites.net

# Stripe publishable key for the PRO checkout (pk_test_... / pk_live_...).
# Optional: leave empty to hide the Stripe payment form on the Upgrade PRO page.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# OAuth social login client IDs. Optional: leave empty to hide the social buttons
# on /login and /register (email/password keeps working).
# The redirect URI registered with each provider (and in the Django backend/allauth)
# must be <app-origin>/auth/callback (e.g. https://equiflow-frontend.vercel.app/auth/callback).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GITHUB_CLIENT_ID=
